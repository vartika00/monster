# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth (get from GitHub → Settings → Developer settings → OAuth Apps)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8001/auth/github/callback

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(64))")
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://localhost:6379

# Agent Configuration
MAX_RETRY_LIMIT=5
DOCKER_SANDBOX_ENABLED=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
